<!DOCTYPE html>
<html>
<body style="margin:0; padding:0; background:#f4f4f4; font-family: Arial, sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0">
<tr><td align="center" style="padding: 2rem 1rem;">
<table width="600" cellpadding="0" cellspacing="0" style="max-width:600px; width:100%;">

  <tr><td style="background:#ffffff; border-radius:8px 8px 0 0; text-align:center; padding: 2rem 2rem 1rem;">
    <img src="https://www.bolokobul.com/assets/bk_logo-d410475b2bfdeb425af379c0193908b7a02336b47f98b379e58edd6ba21c8435.png" width="80" style="margin-bottom:10px;" alt="Bolo Kobul" />
    <div style="font-size:11px; color:#888; letter-spacing:2px; text-transform:uppercase;">Marriages are made in heaven</div>
    <div style="width:40px; height:2px; background:#FFB627; margin:12px auto 0;"></div>
  </td></tr>

  <tr><td style="background:#FFB627; padding: 2rem; text-align:center;">
    <div style="font-size:28px;">🔓</div>
    <div style="font-size:22px; font-weight:bold; color:#ffffff; line-height:1.3; margin-top:8px;">
      Your account has been locked
    </div>
    <div style="font-size:14px; color:#fff3cc; margin-top:8px;">Dear <%= @resource.name.present? ? @resource.name : 'there' %>,</div>
  </td></tr>

  <tr><td style="background:#ffffff; padding: 2rem;">
    <p style="font-size:15px; color:#333333; line-height:1.8; margin:0 0 1rem;">
      Your Bolo Kobul account has been temporarily locked due to too many unsuccessful login attempts. This is a security measure to protect your account.
    </p>
    <p style="font-size:15px; color:#333333; line-height:1.8; margin:0 0 1.5rem;">
      Click the button below to unlock your account and regain access.
    </p>

    <div style="text-align:center; margin: 1.5rem 0;">
      <a href="<%= unlock_url(@resource, unlock_token: @token) %>"
         style="background:#FFB627; color:#ffffff; text-decoration:none; padding:14px 36px; border-radius:6px; font-size:15px; font-weight:bold; display:inline-block;">
        Unlock My Account
      </a>
    </div>

    <div style="background:#FFF8E7; border-left:3px solid #FFB627; padding:14px 16px; margin-bottom:1.5rem;">
      <div style="font-size:13px; color:#555555; line-height:1.7;">
        <strong style="color:#333333;">Was this not you?</strong> If you did not attempt to log in, your account may be at risk. Please contact us immediately at <a href="mailto:support@bolokobul.com" style="color:#FFB627;">support@bolokobul.com</a> or WhatsApp us at <a href="https://wa.me/8801611820410" style="color:#FFB627;">+8801611820410</a>.
      </div>
    </div>
  </td></tr>

  <tr><td style="background:#FFF8E7; padding:1.5rem 2rem; text-align:center; border-top:1px solid #FFE082;">
    <div style="font-size:14px; color:#888888; line-height:1.8;">With warm wishes,</div>
    <div style="font-size:15px; font-weight:bold; color:#FFB627; margin-top:4px;">The Bolo Kobul Team</div>
    <div style="font-size:11px; color:#aaaaaa; margin-top:12px;">
      <a href="https://bolokobul.com" style="color:#FFB627; text-decoration:none;">bolokobul.com</a> &nbsp;|&nbsp;
      <a href="mailto:support@bolokobul.com" style="color:#FFB627; text-decoration:none;">support@bolokobul.com</a>
    </div>
  </td></tr>

</table>
</td></tr>
</table>
</body>
</html>
