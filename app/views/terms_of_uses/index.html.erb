<% content_for :meta_description do %>Read Bolo Kobul's Terms of Use. Understand your rights, membership rules, payment policies, and how we protect you under Bangladeshi law.<% end %>
<div style="background:#f7f5f0; min-height:100vh; padding:24px 0;">
  <div class="container" style="max-width:960px;">
    <div style="border:0.5px solid #eee; border-radius:14px; overflow:hidden; box-shadow:1px 3px 9px rgba(0,0,0,0.07);">

      <!-- Header -->
      <div style="background:linear-gradient(135deg,#FFB627,#ffca5e); padding:28px 24px; text-align:center;">
        <h2 style="font-size:24px; font-weight:700; color:#412402; margin:0 0 6px;">Terms of Use</h2>
        <p style="font-size:13px; color:#633806; margin:0;">Please read carefully before registering on BoloKobul.com</p>
      </div>

      <!-- Two column body -->
      <div style="display:flex; min-height:420px;">

        <!-- Left: index -->
        <div style="width:210px; flex-shrink:0; background:#fafaf8; padding:14px 10px; border-right:0.5px solid #eee;">
          <p style="font-size:10px; font-weight:700; color:#aaa; text-transform:uppercase; letter-spacing:0.06em; margin:0 0 10px; padding:0 4px;">Contents</p>
          <% @terms_of_uses.each_with_index do |term, index| %>
            <div class="bk-tos-nav" data-index="<%= index %>" onclick="bkShowTos(<%= index %>)"
                 style="padding:8px 10px; border-radius:8px; margin-bottom:4px; cursor:pointer; display:flex; align-items:center; gap:8px; <%= index == 0 ? 'background:#FAEEDA; border-left:3px solid #FFB627;' : '' %>">
              <span style="font-size:10px; background:#FFF3CC; color:#854F0B; padding:1px 7px; border-radius:10px; flex-shrink:0; white-space:nowrap;"><%= term.title.match(/^\d+\.\d+/) ? term.title.match(/^\d+\.\d+/)[0] : (term.title.match(/^\d+/) ? term.title.match(/^\d+/)[0] : (index + 1)) %></span>
              <span class="bk-nav-label" style="font-size:12px; color:<%= index == 0 ? '#633806' : '#888' %>; font-weight:<%= index == 0 ? '600' : '400' %>; line-height:1.4;"><%= term.title.gsub(/^\d+\.?\d*\.?\s*/, '') %></span>
            </div>
          <% end %>
        </div>

        <!-- Right: content -->
        <div style="flex:1; padding:24px; background:#fff;">
          <% @terms_of_uses.each_with_index do |term, index| %>
            <div class="bk-tos-content" data-index="<%= index %>" style="<%= index == 0 ? '' : 'display:none;' %>">
              <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px;">
                <div style="width:32px; height:32px; background:#FFB627; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; color:#412402; flex-shrink:0;">
                  <%= term.title.match(/^\d+\.\d+/) ? term.title.match(/^\d+\.\d+/)[0] : (term.title.match(/^\d+/) ? term.title.match(/^\d+/)[0] : (index + 1)) %>
                </div>
                <h3 style="font-size:16px; font-weight:700; color:#633806; margin:0;"><%= term.title.gsub(/^\d+\.?\d*\.?\s*/, '') %></h3>
              </div>
              <div style="font-size:13px; color:#555; line-height:1.9;">
                <%= term.content.html_safe %>
              </div>
              <div style="display:flex; justify-content:space-between; align-items:center; margin-top:28px; padding-top:16px; border-top:0.5px solid #eee;">
                <% if index > 0 %>
                  <button onclick="bkShowTos(<%= index - 1 %>)" style="background:#FFF3CC; color:#854F0B; border:0.5px solid #FFB627; border-radius:8px; padding:8px 16px; font-size:12px; font-weight:600; cursor:pointer;">
                    ← Previous
                  </button>
                <% else %>
                  <span></span>
                <% end %>
                <% if index < @terms_of_uses.count - 1 %>
                  <button onclick="bkShowTos(<%= index + 1 %>)" style="background:#FFB627; color:#412402; border:none; border-radius:8px; padding:8px 20px; font-size:12px; font-weight:600; cursor:pointer;">
                    Next: <%= @terms_of_uses[index + 1]&.title %> →
                  </button>
                <% else %>
                  <span style="font-size:12px; color:#aaa;">End of Terms</span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
function bkShowTos(index) {
  document.querySelectorAll('.bk-tos-content').forEach(function(el) {
    el.style.display = 'none';
  });
  var content = document.querySelector('.bk-tos-content[data-index="' + index + '"]');
  if (content) content.style.display = 'block';

  document.querySelectorAll('.bk-tos-nav').forEach(function(el) {
    var i = parseInt(el.getAttribute('data-index'));
    var label = el.querySelector('.bk-nav-label');
    if (i === index) {
      el.style.background = '#FAEEDA';
      el.style.borderLeft = '3px solid #FFB627';
      label.style.color = '#633806';
      label.style.fontWeight = '600';
    } else {
      el.style.background = '';
      el.style.borderLeft = '';
      label.style.color = '#888';
      label.style.fontWeight = '400';
    }
  });
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>
