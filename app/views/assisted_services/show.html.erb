<div style="background:#f7f5f0; min-height:100vh; padding:24px 0;">
  <div class="container" style="max-width:960px;">

    <div style="display:grid; grid-template-columns:1fr 300px; gap:20px; align-items:flex-start;">

      <!-- Left: content -->
      <div>

        <!-- Title header -->
        <div style="background:linear-gradient(135deg,#FFB627,#ffca5e); border-radius:14px; padding:24px; margin-bottom:16px;">
          <h2 style="font-size:22px; font-weight:700; color:#412402; margin:0 0 6px;"><%= @assisted_service.page_title %></h2>
          <p style="font-size:13px; color:#633806; margin:0;">Professional assistance by the BoloKobul team</p>
        </div>

        <!-- Page content -->
        <div style="border:0.5px solid #FAC775; border-radius:14px; background:#fff; padding:24px; font-size:13px; color:#555; line-height:1.9;">
          <%= @assisted_service.page_content.html_safe %>
        </div>

      </div>

      <!-- Right: purchase card -->
      <div style="border:0.5px solid #FAC775; border-radius:14px; overflow:hidden; background:#fff; position:sticky; top:20px;">

        <!-- Price header -->
        <div style="background:linear-gradient(135deg,#FFB627,#ffca5e); padding:18px; text-align:center;">
          <p style="font-size:11px; color:#633806; margin:0 0 4px; font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">Service Price</p>
          <p style="font-size:28px; font-weight:700; color:#412402; margin:0;">৳ <%= number_with_delimiter(@assisted_service.price.to_i) %> <span style="font-size:13px; color:#633806;">BDT</span></p>
        </div>

        <!-- Form -->
        <div style="padding:18px;">
          <div style="background:#FAEEDA; border-radius:8px; padding:10px 14px; margin-bottom:16px; font-size:12px; color:#633806; display:flex; align-items:center; gap:8px;">
            <i class="fas fa-shield-alt" style="font-size:15px;"></i>
            Secure payment · Instant activation
          </div>

          <%= form_for Order.new do |f| %>
            <%= f.hidden_field :quantity, value: 1 %>
            <%= f.hidden_field :payment_method, value: "foster_payment" %>
            <%= f.hidden_field :product, value: "assisted_service" %>
            <%= f.hidden_field :assisted_service_id, value: @assisted_service.id %>

            <% unless current_user %>
              <div style="margin-bottom:14px;">
                <p style="font-size:12px; color:#854F0B; font-weight:600; margin:0 0 10px;">Please share your details or
                  <a href="#" data-toggle="modal" data-target="#loginModal" style="color:#412402; font-weight:700;">Login</a>
                </p>
                <%= f.text_field :customer_name,
                                 required: true,
                                 placeholder: 'Your Name*',
                                 style: "width:100%; background:#fafaf8; border:0.5px solid #FAC775; border-radius:8px; padding:9px 12px; font-size:13px; margin-bottom:8px; box-sizing:border-box;" %>
                <%= f.text_field :customer_phone,
                                 required: true,
                                 placeholder: 'Your Phone Number*',
                                 style: "width:100%; background:#fafaf8; border:0.5px solid #FAC775; border-radius:8px; padding:9px 12px; font-size:13px; margin-bottom:8px; box-sizing:border-box;" %>
                <%= f.text_field :customer_email,
                                 placeholder: 'Your Email Address',
                                 style: "width:100%; background:#fafaf8; border:0.5px solid #FAC775; border-radius:8px; padding:9px 12px; font-size:13px; margin-bottom:8px; box-sizing:border-box;" %>
              </div>
            <% end %>

            <button type="submit" style="width:100%; background:linear-gradient(135deg,#FFB627,#ffca5e); color:#412402; border:none; border-radius:8px; padding:12px; font-size:14px; font-weight:700; cursor:pointer; margin-bottom:10px;">
              Purchase Now
            </button>
            <p style="font-size:11px; color:#aaa; text-align:center; margin:0;">By purchasing you agree to our terms of service</p>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>
