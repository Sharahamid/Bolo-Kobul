<div class="right-section mb-4">
  <div style="border:0.5px solid #FAC775; border-radius:14px; overflow:hidden; box-shadow:1px 3px 9px rgba(0,0,0,0.07);">

    <!-- Header -->
    <div style="background:linear-gradient(135deg,#FFB627,#ffca5e); padding:14px 18px; display:flex; align-items:center; gap:8px;">
      <i class="fas fa-lock" style="color:#412402; font-size:16px;"></i>
      <span style="font-size:15px; font-weight:700; color:#412402;">Privacy Information</span>
    </div>

    <!-- 3-column grid -->
    <div style="padding:14px; background:#fffaf0; display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px;">

      <% [
        ['Gender', 'gender', @privacy_setting&.gender&.humanize],
        ['Date of Birth', 'date_of_birth', @privacy_setting&.date_of_birth&.humanize],
        ['Height', 'height_ft', @privacy_setting&.height_ft&.humanize],
        ['Highest Education', 'highest_education_level', @privacy_setting&.highest_education_level&.humanize],
        ['Current Occupation', 'current_occupation', Occupation::OCCUPATION_LABELS[@privacy_setting&.current_occupation] || @privacy_setting&.current_occupation&.humanize],
        ['Physical Status', 'physical_status', @privacy_setting&.physical_status&.humanize],
        ['Family Values', 'family_values', @privacy_setting&.family_values&.humanize],
        ['Family Type', 'family_type', @privacy_setting&.family_type&.humanize],
        ['Family Status', 'family_status', @privacy_setting&.family_status&.humanize]
      ].each do |label, field, value| %>
        <div style="border:0.5px solid #FAC775; border-radius:10px; background:#fff; padding:12px 14px; display:flex; align-items:center; justify-content:space-between; gap:8px;">
          <div style="min-width:0;">
            <p style="font-size:12px; font-weight:600; color:#412402; margin:0 0 3px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= label %></p>
            <p style="font-size:11px; color:#aaa; margin:0; display:flex; align-items:center; gap:4px;">
              <%= render 'privacy_settings/privacy_icon', privacy_setting: @privacy_setting, field_name: field %>
              <%= value %>
            </p>
          </div>
          <%= render 'privacy_settings/privacy_toggle_switch', privacy_setting: @privacy_setting, field_name: field %>
        </div>
      <% end %>

    </div>
  </div>
</div>
