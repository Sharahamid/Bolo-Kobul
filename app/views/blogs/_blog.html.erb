<div style="border:0.5px solid #FAC775; border-radius:10px; background:#fffaf0; overflow:hidden; margin-bottom:10px; display:flex; align-items:center;">
  <div style="width:140px; min-height:120px; flex-shrink:0; overflow:hidden; background:#fff8ee;">
    <%= image_tag "#{blog.image_url.present? ? blog.image_url : 'bg01.jpg'}",
                  style: "width:140px; height:140px; object-fit:contain; background:#fff8ee; display:block;",
                  class: "img-responsive" %>
  </div>
  <div style="padding:12px 16px; flex:1; min-width:0;">
    <h4 style="font-size:14px; font-weight:700; color:#633806; margin:0 0 6px; line-height:1.4;">
      <%= blog.title %>
    </h4>
    <div style="font-size:12px; color:#777; line-height:1.6; margin-bottom:10px; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
      <%=raw blog.story %>
    </div>
    <%= link_to blog_path(blog), style: "background:#FAEEDA; color:#854F0B; border:0.5px solid #FFB627; border-radius:6px; padding:5px 12px; font-size:11px; font-weight:600; text-decoration:none; display:inline-block;" do %>
      Read Full Story →
    <% end %>
  </div>
</div>
