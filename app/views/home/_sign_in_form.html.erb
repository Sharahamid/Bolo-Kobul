<%= form_for("user", :url => user_session_path) do |f| %>
<div class="bk-login-form">
  <div class="text-center">
    <%= image_tag 'bk_logo.webp', width: '85', height: '85' %>
    <div class="text-center pb-4">
     <span class="text-gray"> Don't wait for love to find you. </span> <br>
      <strong> Login Now! </strong>
    </div>
  </div>

  <div class="form-group">
    <%= f.text_field :login,
                     type: 'phone',
                     class: 'form-control',
                     placeholder: 'Email / Mobile (+8801xxxxxxxx)',
                     required: true  %>
  </div>

  <div class="form-group">
    <div style="display: flex; align-items: center; border: 1px solid #ced4da; border-radius: 4px; background: white;">
      <%= f.text_field :password, type: 'password',
                       class: 'form-control',
                       id: 'login_password',
                       placeholder: 'Password',
                       style: 'border: none; box-shadow: none; flex: 1;',
                       required: true %>
      <button type="button" onclick="togglePassword('login_password', this)"
        style="background: none; border: none; border-left: 1px solid #ced4da;
               cursor: pointer; color: #666; font-size: 16px; padding: 0 10px;
               height: 38px;">
        <i class="fas fa-eye"></i>
      </button>
    </div>
  </div>

  <div class="d-flex flex-row remember-password">
    <div class="checkbox flex-fill">
      <label class="bk-check-box">
        <%= f.check_box :remember_me %>
        <span class=""> Remember me </span>
      </label>
    </div>


    <div class="forget-password">
      <%= link_to 'Forgot Password?', new_user_password_path, class: ''%>
    </div>
  </div>


  <div class="bk-login-btn">
    <%= f.submit 'LOGIN', class: 'form-control btn btn-warning text-white' %>
  </div>

</div>

<% end %>

<script>
  function togglePassword(inputId, button) {
    var input = document.getElementById(inputId);
    if (input.type === "password") {
      input.type = "text";
      button.innerHTML = '<i class="fas fa-eye-slash"></i>';
    } else {
      input.type = "password";
      button.innerHTML = '<i class="fas fa-eye"></i>';
    }
  }
</script>
