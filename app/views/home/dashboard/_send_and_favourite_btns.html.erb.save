
<div style="display:flex; gap:8px; margin-top:2px;">
  <% if current_active_profile.pending_friends.include?(marriage_profile) %>
    <a href="#" class="kobul_btn" style="flex:1; font-size:11px; padding:8px 4px; border-radius:8px !important; border-color:#FFB627 !important; color:#854F0B !important; display:flex; align-items:center; justify-content:center; gap:4px;" data-toggle="tooltip" title="You Have Sent Butterfly Request To This User">
      🦋 Pending
    </a>
  <% else %>
    <a href="<%= send_request_marriage_profile_path(marriage_profile) %>" data-method="post" class="kobul_btn" style="flex:1; font-size:11px; padding:8px 4px; border-radius:8px !important; border-color:#FFB627 !important; color:#854F0B !important; display:flex; align-items:center; justify-content:center; gap:4px;" data-toggle="tooltip" title="Send butterfly to request more details">
      🦋 Kobul (1)
    </a>
  <% end %>
  <% if @marriage_profile.favourite_profile_ids.include?(marriage_profile.id) %>
    <%= link_to remove_favourites_path(favourite_profile_id: marriage_profile.id),
                method: :delete,
                id: "fav_#{@marriage_profile.id}_to_#{marriage_profile.id}",
                class: 'kobul_cancel-btn',
                style: 'flex:1; font-size:11px; padding:8px 4px; border-radius:8px !important; display:flex; align-items:center; justify-content:center; gap:4px;',
                data: {toggle: 'tooltip', placement: 'top'},
                title: "Remove from favourites" do %>
      <i class="fa fa-close"></i> Remove
    <% end %>
  <% else %>
    <%= link_to favourites_path(favourite_profile_id: marriage_profile.id),
                method: :post,
                id: "fav_#{@marriage_profile.id}_to_#{marriage_profile.id}",
                class: 'bk_favourite-btn',
                style: 'flex:1; font-size:11px; padding:8px 4px; border-radius:8px !important; display:flex; align-items:center; justify-content:center; gap:4px;',
                data: {toggle: 'tooltip', placement: 'top'},
                title: "Save to favourites" do %>
      <i class="far fa-heart"></i> Favourite
    <% end %>
  <% end %>
</div>
