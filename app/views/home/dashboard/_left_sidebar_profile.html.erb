<div class="left-sidebar-card p-3">
  <div class="left-side-single-card d-flex flex-column align-content-center">
    <div class="profile-photo align-self-center p-1">
      <%= render 'home/dashboard/profile_photo', marriage_profile: marriage_profile %>
    </div>
    <div class="card_title align-self-center p-1">
      <%- if marriage_profile&.id == current_active_profile&.id %>
        <strong><%= marriage_profile&.name&.split&.first %></strong>
      <% end %>
      <%- if marriage_profile&.verified %>
        <i title="Verified" class="fas fa-check-circle"></i>
      <% end %>
    </div>
    <div class="card_title align-self-center p-1">
      <%= marriage_profile&.unique_id %>
    </div>
    <% if marriage_profile&.id == current_active_profile&.id %>
      <%= render 'shared/profile_progress_bar' %>
      <%= render 'home/dashboard/short_profile_content' %>
      <%= render 'home/dashboard/create_and_edit_btns' %>
    <% else %>
      <%= render 'home/dashboard/short_profile_content_for_others', marriage_profile: marriage_profile %>
      <div class="request-card-bottom p-2 border-top">
        <% if current_active_profile.chat_friendships.where(status: 2).map(&:chat_friend_id).include?(marriage_profile.id) %>
          <%= link_to "Chat", profile_message_path(marriage_profile), class: 'kobul_btn kobul_2' %>
        <% elsif current_active_profile.chat_friendships.where(status: 0).map(&:chat_friend_id).include?(marriage_profile.id) %>
          <div class="col-12">
            <div class="row">
              <div class="bk-request-btn col-6 p-0">
                <a href="#" class="kobul_btn kobul_2" data-toggle="tooltip" data-placement="top" title="Waiting for Kobul 2 response">
                  <span>Kobul 2 Pending</span>
                </a>
              </div>
              <% if current_active_profile.favourite_profile_ids.include?(marriage_profile.id) %>
                <div class="bk-cancel-btn col-6 p-0">
                  <%= link_to remove_favourites_path(favourite_profile_id: marriage_profile.id), method: :delete, class: 'kobul_cancel-btn', data: {toggle: 'tooltip', placement: 'top'}, title: "Remove from favourites" do %>
                    <i class="fa fa-close"></i> Remove
                  <% end %>
                </div>
              <% else %>
                <div class="bk-cancel-btn col-6 p-0">
                  <%= link_to favourites_path(favourite_profile_id: marriage_profile.id), method: :post, class: 'bk_favourite-btn', data: {toggle: 'tooltip', placement: 'top'}, title: "Save to Favourites" do %>
                    <i class="far fa-heart"></i> Favourite
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% elsif get_requested_profiles.include?(marriage_profile) %>
          <%= render 'home/dashboard/accept_and_cancel_btns', profile: marriage_profile %>
        <% elsif current_active_profile.pending_friends.include?(marriage_profile) %>
          <div class="col-12">
            <div class="row">
              <div class="bk-request-btn col-6 p-0">
                <a href="#" class="kobul_btn" data-toggle="tooltip" data-placement="top" title="You Have Sent Butterfly Request To This User">
                  <span>
                    <%= image_tag 'butterfly_kobul_hover.svg', width: '14', height: '14', class: 'kobul-hover-butterfly' %>
                    <%= image_tag 'butterfly_kobul.svg', class: 'kobul-butterfly' %>
                    Pending
                  </span>
                </a>
              </div>
              <% if current_active_profile.favourite_profile_ids.include?(marriage_profile.id) %>
                <div class="bk-cancel-btn col-6 p-0">
                  <%= link_to remove_favourites_path(favourite_profile_id: marriage_profile.id), method: :delete, class: 'kobul_cancel-btn', data: {toggle: 'tooltip', placement: 'top'}, title: "Remove from favourites" do %>
                    <i class="fa fa-close"></i> Remove
                  <% end %>
                </div>
              <% else %>
                <div class="bk-cancel-btn col-6 p-0">
                  <%= link_to favourites_path(favourite_profile_id: marriage_profile.id), method: :post, class: 'bk_favourite-btn', data: {toggle: 'tooltip', placement: 'top'}, title: "Save to Favourites" do %>
                    <i class="far fa-heart"></i> Favourite
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% elsif Friendship.where('(friendable_id = ? AND friend_id = ?) OR (friendable_id = ? AND friend_id = ?)', current_active_profile.id, marriage_profile.id, marriage_profile.id, current_active_profile.id).where(status: 1).exists? %>
          <%= render 'home/dashboard/kobul_2_btn', profile: marriage_profile %>
        <% elsif current_active_profile.favourite_profiles.include?(marriage_profile) %>
          <%= render 'home/dashboard/send_butterfly_and_remove_favourite_btns', profile: marriage_profile %>
        <% else %>
          <%= render 'home/dashboard/send_and_favourite_btns', marriage_profile: marriage_profile %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
