<div style="display:flex; gap:8px; padding:0 8px 8px;">
  <% if current_active_profile&.chat_friendships&.where(status: 2)&.map(&:chat_friend_id)&.include?(profile.id) %>
    <%= link_to profile_message_path(profile),
                class: "kobul_btn kobul_2",
                style: "flex:1; font-size:11px; padding:8px 4px; border-radius:8px !important; display:flex; align-items:center; justify-content:center; gap:4px;" do %>
      🦋 Chat
    <% end %>
  <% elsif current_active_profile&.chat_friendships&.map(&:chat_friend_id)&.include?(profile.id) %>
    <a href="#" class="kobul_btn kobul_2"
       style="flex:1; font-size:11px; padding:8px 4px; border-radius:8px !important; display:flex; align-items:center; justify-content:center; gap:4px;"
       data-toggle="tooltip" title="Kobul 2 request pending">
      🦋 Pending
    </a>
  <% else %>
    <a href="<%= send_request_chat_friendship_path(profile) %>"
       class="kobul_btn kobul_2"
       data-method="post"
       data-butterfly-target="bk-target-chats"
       style="flex:1; font-size:11px; padding:8px 4px; border-radius:8px !important; display:flex; align-items:center; justify-content:center; gap:4px;"
       data-toggle="tooltip" title="Send Kobul 2 to start chatting">
      🦋 Kobul (2)
    </a>
  <% end %>

  <%= link_to reject_request_chat_friendship_path(profile),
              method: :patch,
              data: { confirm: "Reject this Kobul 1 request?" },
              class: "kobul_cancel-btn",
              style: "flex:1; font-size:11px; padding:8px 4px; border-radius:8px !important; display:flex; align-items:center; justify-content:center; gap:4px;" do %>
    <i class="fa fa-close"></i> Reject
  <% end %>
</div>
