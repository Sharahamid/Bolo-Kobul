<div class="request-card flex-sm-fill" style="border-radius:10px; overflow:hidden; border:0.5px solid #eee;">
  <div style="background:linear-gradient(135deg,#FFB627,#ffca5e); padding:10px 14px;">
    <span style="font-size:13px; font-weight:700; color:#633806;">2nd Kobul Request Received</span>
  </div>
  <div class="recommended_profiles mb-4">
    <% if get_accepted_profiles.present? %>
      <% get_accepted_profiles.each do |accepted_profile| %>
        <div class="flex-fill border-bottom">
          <div class="d-flex flex-column">
            <%= render 'home/dashboard/card_profile_info', profile: accepted_profile, profile_action: true %>
            <div class="request-card-bottom p-2 border-top">
              <%= render 'home/dashboard/kobul_2_btn', profile: accepted_profile %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="alert text-center text-gray" style="padding:24px 16px;">
        <i class="fa fa-user-plus" style="font-size:28px; color:#ddd; display:block; margin-bottom:8px;"></i>
        <p>You have no accepted profiles yet.</p>
      </div>
    <% end %>
  </div>
</div>
