<div class="request-card flex-sm-fill" style="border-radius:10px; overflow:hidden; border:0.5px solid #eee;">
  <div style="background:linear-gradient(135deg,#FFB627,#ffca5e); padding:10px 14px; display:flex; align-items:center; justify-content:space-between;">
    <span style="font-size:13px; font-weight:700; color:#633806;">1st Kobul Request Received</span>
    <% if get_requested_profiles.present? %>
      <span style="background:#633806; color:#FAC775; font-size:10px; padding:1px 8px; border-radius:20px;"><%= get_requested_profiles.count %></span>
    <% end %>
  </div>
  <div class="mb-4 <%= get_requested_profiles&.count.to_i > 2 ? 'bk-request-slider' : '' %>">
    <% if get_requested_profiles.present? %>
      <% get_requested_profiles.each do |requested_profile| %>
        <div class="request-card border-bottom" style="position:relative;" data-profile-card="true">
          <div class="d-flex flex-column">
            <%= render 'home/dashboard/card_profile_info', profile: requested_profile, profile_action: true %>
            <div class="request-card-bottom p-2 border-top">
              <%= render 'home/dashboard/accept_and_cancel_btns', profile: requested_profile %>
            </div>
            <div style="position:absolute; top:8px; right:8px;">
              <%= render 'shared/profile_actions', profile: requested_profile %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="alert text-center text-gray" style="padding:40px 16px; min-height:110px; display:flex; align-items:center; justify-content:center;">
        <p style="margin:0;">No Request Yet</p>
      </div>
    <% end %>
  </div>
</div>
