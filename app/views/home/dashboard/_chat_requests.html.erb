<div style="border-radius:10px; overflow:hidden; background:#fff; box-shadow:1px 3px 9px rgba(0,0,0,0.08); margin:0 0.75rem 12px; width:calc(100% - 1.5rem);">
  <div style="background:linear-gradient(135deg,#FFB627,#ffca5e); padding:10px 16px; display:flex; align-items:center; gap:8px;">
    <i class="fa fa-comments" style="color:#633806;"></i>
    <span id="bk-target-chats" style="font-size:13px; font-weight:700; color:#633806;">Chats (3rd Kobul awaits)</span>
  </div>
  <div style="display:flex; flex-wrap:wrap; gap:8px; padding:10px;">
    <% chat_channels&.each do |chat_room| %>
      <% profile = chat_room.connected_profile(current_active_profile) %>
      <div style="border:0.5px solid #eee; border-radius:8px; background:#fffaf0; min-width:160px; flex:1;">
        <%= render 'messages/single_chat_profile', profile: profile, chat_room: chat_room %>
      </div>
    <% end %>
  </div>
</div>
