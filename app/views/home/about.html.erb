<% content_for :meta_description do %>Learn about Bolo Kobul — Bangladesh's all-in-one matchmaking platform with our unique 3 Kobul system, verified profiles, and wedding planning directory.<% end %>
<div style="background:#f7f5f0; min-height:100vh; padding:24px 0;">
  <div class="container">
    <div style="display:grid; grid-template-columns:1fr 240px; gap:20px; align-items:flex-start;">

      <!-- Left: about content -->
      <div>
        <%= render 'shared/about_content', about_content: @about_content %>
      </div>

      <!-- Right: ad -->
      <div>
        <%= render partial: 'shared/ad_for_about_page' %>
      </div>

    </div>
    <%= render 'home/landing/campaign' unless user_signed_in? %>
  </div>
</div>
