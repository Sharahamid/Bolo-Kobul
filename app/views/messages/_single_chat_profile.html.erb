<div style="padding:10px 12px; border-bottom:0.5px solid #f5f5f5;">
  <div style="display:flex; align-items:center; gap:10px; margin-bottom:6px;">
    <div onclick="bkOpenPhoto('<%= profile.profile_image.large_profile_thumb.url rescue '' %>')" style="cursor:pointer; flex-shrink:0;">
      <%= render 'shared/chat_profile_photo', profile: profile %>
    </div>
    <div style="flex:1; min-width:0;">
      <div style="display:flex; align-items:center; gap:4px; margin-bottom:4px;">
        <%= link_to profile_message_path(profile), style: "font-weight:700; color:#854F0B; font-size:13px; text-decoration:none;" do %>
          <%= profile&.unique_id %><%= " (#{profile.user.created_for})" unless profile.user.self? %>
        <% end %>
        <% if profile.verified %>
          <i class="fas fa-check-circle" style="color:#FFB627; font-size:11px;"></i>
        <% end %>
        <% if profile.matching_percentage.present? %>
          <span style="background:#FFB627; color:#633806; font-size:9px; padding:1px 5px; border-radius:10px; margin-left:auto; font-weight:700;"><%= "%02d" % profile.matching_percentage %>%</span>
        <% end %>
      </div>
      <div style="display:flex; flex-wrap:wrap; gap:3px; margin-bottom:3px; align-items:center;">
        <span style="background:#FFF3CC; color:#854F0B; font-size:10px; padding:1px 6px; border-radius:5px;"><%= profile.age %> years</span>
        <span style="background:#FFF3CC; color:#854F0B; font-size:10px; padding:1px 6px; border-radius:5px;"><%= profile.height_ft %>'<%= profile.height_inch %>''</span>
        <span style="background:#FFF3CC; color:#854F0B; font-size:10px; padding:1px 6px; border-radius:5px;"><i class="fas fa-map-marker-alt" style="color:#854F0B; font-size:9px; margin-right:2px;"></i><%= profile&.hometown&.humanize %></span>
      </div>
      <div style="font-size:10px; color:#999; display:flex; align-items:center; flex-wrap:wrap; gap:3px; margin-bottom:4px;">
        <span style="display:inline-flex; align-items:center; gap:2px;"><i class="fas fa-graduation-cap" style="color:#FFB627; font-size:10px;"></i><%= profile.highest_education_level? ? profile.highest_education_level.humanize : '' %></span>
        <% if profile.current_occupation.present? %>
          <span>&middot;</span>
          <span style="display:inline-flex; align-items:center; gap:2px;"><i class="fas fa-briefcase" style="color:#FFB627; font-size:10px;"></i><%= Occupation::OCCUPATION_LABELS[profile.current_occupation] || profile.current_occupation.humanize %></span>
        <% end %>
      </div>
      <div style="display:flex; align-items:center; gap:6px;">
        <% message = chat_room&.messages&.last %>
        <span style="font-size:10px; color:#aaa; flex:1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><i class="fa fa-comment" style="font-size:9px; margin-right:3px;"></i><%= message.present? ? truncate(message&.body, length: 25) : 'New conversation' %></span>
        <small style="color:#ccc; font-size:9px; white-space:nowrap;"><%= message.present? ? format_date_chat(message.created_at) : '' %></small>
      </div>
    </div>
  </div>
</div>
