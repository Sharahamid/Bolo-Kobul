<% message = chat_room&.messages&.last %>
<div style="padding:10px 12px; border-bottom:0.5px solid #FAC775; background:#fff; cursor:pointer;">
  <div style="display:flex; align-items:flex-start; gap:10px;">
    <div onclick="bkOpenPhoto('<%= profile.profile_image.large_profile_thumb.url rescue '' %>')" style="cursor:pointer; flex-shrink:0;">
      <%= render 'shared/chat_profile_photo', profile: profile %>
    </div>
    <div style="flex:1; min-width:0;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:4px;">
        <%= link_to profile_message_path(profile), style: "font-size:13px; font-weight:700; color:#854F0B; text-decoration:none;" do %>
          <%= profile&.unique_id %><%= " (#{profile.user.created_for})" unless profile.user.self? %>
          <% if profile.verified %>
            <i class="fas fa-check-circle" style="color:#FFB627; font-size:10px;"></i>
          <% end %>
        <% end %>
        <small style="color:#ccc; font-size:9px; white-space:nowrap;"><%= message.present? ? format_date_chat(message.created_at) : '' %></small>
      </div>
      <div style="display:flex; flex-wrap:wrap; gap:3px; margin-bottom:5px;">
        <span style="background:#FFF3CC; color:#854F0B; font-size:9px; padding:1px 6px; border-radius:4px;"><%= profile.age %> yrs</span>
        <span style="background:#FFF3CC; color:#854F0B; font-size:9px; padding:1px 6px; border-radius:4px;"><%= profile.height_ft %>'<%= profile.height_inch %>"</span>
        <span style="background:#FFF3CC; color:#854F0B; font-size:9px; padding:1px 6px; border-radius:4px;"><i class="fas fa-map-marker-alt" style="font-size:8px;"></i> <%= profile&.hometown&.humanize %></span>
      </div>
      <div style="display:flex; align-items:center; justify-content:space-between; gap:6px;">
        <span style="font-size:10px; color:#aaa; flex:1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
          <i class="fa fa-comment" style="font-size:9px; margin-right:2px;"></i>
          <%= message.present? ? truncate(message&.body, length: 22) : 'New conversation' %>
        </span>
        <%= link_to profile_info_marriage_profile_path(profile),
                    target: '_blank',
                    style: "font-size:9px; background:#FFB627; color:#412402; border-radius:4px; padding:3px 7px; text-decoration:none; font-weight:700; white-space:nowrap; flex-shrink:0;" do %>
          View Profile
        <% end %>
      </div>
    </div>
  </div>
</div>
