<div style="border:0.5px solid #FAC775; border-radius:12px; background:#fffaf0; overflow:hidden; display:flex; flex-direction:column;">
  <a href="<%= market_place_path market_place %>" style="text-decoration:none;">
    <div style="height:160px; overflow:hidden; background:#f0e8d0;">
      <%= image_tag "#{market_place.image_url.present? ? market_place.image_url : 'bg02.jpg'}",
                    style: "width:100%; height:160px; object-fit:cover;",
                    class: "img-responsive" %>
    </div>
    <div style="padding:12px;">
      <h4 style="font-size:13px; font-weight:700; color:#633806; margin:0 0 4px;"><%= market_place.name.truncate(30) %></h4>
      <p style="font-size:11px; color:#aaa; margin:0 0 8px; display:flex; align-items:center; gap:4px;">
        <i class="fas fa-map-marker-alt" style="color:#EF9F27;"></i> <%= market_place.location %>
      </p>
      <% if market_place.service_coverage.present? %>
        <p style="font-size:11px; color:#888; margin:0 0 8px;"><%= market_place.service_coverage.truncate(50) %></p>
      <% end %>
      <div style="display:flex; align-items:center; justify-content:space-between;">
        <% if market_place.cost.present? %>
          <span style="font-size:13px; font-weight:700; color:#854F0B;">৳ <%= number_with_delimiter(market_place.cost) %></span>
        <% else %>
          <span></span>
        <% end %>
        <span style="background:#FAEEDA; color:#854F0B; border:0.5px solid #FFB627; border-radius:6px; padding:4px 10px; font-size:11px; font-weight:600;">View →</span>
      </div>
    </div>
  </a>
</div>
