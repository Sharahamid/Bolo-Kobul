<div class="right-section mb-4">
  <div class="dashboard-tab">
    <div style="background:#FFB627; padding:14px 20px; border-radius:5px 5px 0 0; display:flex; align-items:center; justify-content:center; gap:10px;">
      <span style="color:#633806; font-size:15px; font-weight:700;">Chat Requests Sent</span>
      <% if @pending_chat_profiles.present? %>
        <span style="background:#633806; color:#FAC775; font-size:11px; padding:2px 10px; border-radius:20px; font-weight:600;"><%= @pending_chat_profiles.count %></span>
      <% end %>
    </div>
    <div style="padding:16px; background:#fff; max-width:500px; margin:0 auto;">
      <% if @pending_chat_profiles.present? %>
        <% @pending_chat_profiles.each_with_index do |profile, index| %>
          <div style="display:flex; gap:14px; align-items:flex-start; margin-bottom:8px;">
            <div style="display:flex; flex-direction:column; align-items:center;">
              <div style="width:40px; height:40px; border-radius:50%; background:#FFF3CC; border:2px solid #FFB627; display:flex; align-items:center; justify-content:center; font-size:18px; flex-shrink:0;">🦋</div>
              <% unless index == @pending_chat_profiles.count - 1 %>
                <div style="width:2px; height:30px; background:#FFB627; opacity:0.3; margin-top:4px;"></div>
              <% end %>
            </div>
            <div style="flex:1; padding-top:4px;">
              <div style="font-weight:700; color:#854F0B; font-size:14px;">
                <%= link_to profile&.unique_id, profile_info_marriage_profile_path(profile), style: "color:#854F0B; text-decoration:none;" %>
              </div>
              <div style="font-size:12px; color:#888; margin-top:2px;">Kobul 2 sent &middot; awaiting response</div>
              <div style="display:flex; gap:8px; margin-top:10px;">
                <%= link_to profile_info_marriage_profile_path(profile), style: "font-size:12px; background:#FFF3CC; color:#854F0B; padding:5px 14px; border-radius:8px; text-decoration:none; border:0.5px solid #FFB627;" do %>
                  View Profile
                <% end %>
                <%= link_to reject_request_chat_friendship_path(profile),
                            method: :patch,
                            data: { confirm: "Cancel this Kobul 2 request?" },
                            style: "font-size:12px; background:#FCEBEB; color:#A32D2D; padding:5px 14px; border-radius:8px; text-decoration:none; border:0.5px solid #F09595;" do %>
                  Cancel
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <%= render 'shared/no_data_found' %>
      <% end %>
    </div>
  </div>
</div>
