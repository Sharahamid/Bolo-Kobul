<div class="container-fluid p-0">
  <div class="container">
    <div class="basic_info">
      <div class="basic-info-mandala">
        <%= image_tag 'mandala.svg', class: 'img-responsive' %>
      </div>
      <div class="d-flex flex-column align-items-center">
        <div class="internal_form_heading align-self-center">
          <%= image_tag 'basic_info_form_title.svg', width: '100%', class: "img-responsive" %>
        </div>
        <div class="form_title align-self-start pt-3 pl-2 pr-2">
          <strong> Basics </strong> <br>
          <%= image_tag 'yellow_line.svg', width: '51.59', height: '17' %>
        </div>
	<div class="alert mt-2 mb-3" role="alert" style="font-size:0.95rem; background-color: rgb(255,182,39); color:white; border:none;">
          Your personal info is safe with us — Name and NID will not be shown to others
	</div>
        <div class="form_input_fields pt-4 pl-2 pr-2">
          <%= form_for @marriage_profile do |f| %>

            <div class="form-group">
              <%= f.text_field :name,
                               autofocus: true,
                               autocomplete: "name",
                               class: 'form-control sign_up-input-field',
                               placeholder: 'Full Name',
                               required: true,
                               data: {toggle: "tooltip", placement: "top" },
                               title: "Full Name" %>
              <small class="text-danger"> <%= f.object.errors[:name].present? ? f.object.errors[:name]&.first : '' %> </small>
            </div>

            <div class="form-group">
              <%= f.text_field :nid_or_passport,
                               autocomplete: "nid_or_passport",
                               class: 'form-control sign_up-input-field',
                               placeholder: 'NID or Passport No.',
                               minlength: '6',
                               data: {toggle: "tooltip", placement: "top" },
                               title: "NID or Passport No.* 🔐 (information cannot be edited once submitted)" %>
              <small class="text-danger"> <%= f.object.errors[:nid_or_passport].present? ? f.object.errors[:nid_or_passport]&.first : '' %> </small>
            </div>

            <div class="form-group">
              <div>Upload A Clear Identification Document</div>
              <%= f.file_field :identification_document, required: true,
                               class: 'form-control sign_up-input-field',
                               style: 'padding: 3px',
                               data: {toggle: "tooltip", placement: "top" },
                               title: 'NID, passport, birth certificate, driving license, office ID' %>
              <small class="text-danger">
                <%= f.object.errors[:identification_document].present? ? f.object.errors[:identification_document]&.first : '' %>
              </small>
            </div>

            <div class="form-group">
              <%= f.select :gender,
                           MarriageProfile::genders.sort_by { |k, v| k }.to_h.map { |k, v| [k.humanize, k] },
                           {prompt: 'Gender*'},
                           required: true,
                           class: 'form-control sign_up-input-field',
                           data: {toggle: "tooltip", placement: "top" },
                           title: "Gender* 🔐" %>
              <small class="text-danger"> <%= f.object.errors[:gender].present? ? f.object.errors[:gender]&.first : '' %> </small>
            </div>
            <div class="form-group" id="other_gender_field" style="display:none;">
              <%= f.text_field :other_gender, placeholder: 'Please specify your gender*', class: 'form-control sign_up-input-field', id: 'other_gender_input' %>
            </div>

            <div class="form-group">
	      <%= f.label :date_of_birth, "Date of Birth", class: "form-label" %>
              <%= f.date_field :date_of_birth,
                               max: Date.today.years_ago(18),
                               autofocus: true,
                               class: 'form-control sign_up-input-field',
                               title:'Date of Birth* 🔐 (information cannot be edited once submitted)',
                               required: true,
			       placeholder: 'Date of Birth (dd/mm/yyyy)',   # behaves like prompt
                               data: {toggle: "tooltip", placement: "top" } %>
              <small class="text-danger"> <%= f.object.errors[:date_of_birth].present? ? f.object.errors[:date_of_birth]&.first : '' %> </small>
            </div>

	    <div class="form-group">
              <%= f.select :marital_status,
                           MarriageProfile::marital_statuses.reject { |k, v| k == "married" }.sort_by { |k, v| k }.to_h.map { |k, v| [k.humanize, k] },
                           {prompt: 'Marital Status*'},
                           class: 'form-control sign_up-input-field',
                           required: true,
                           data: {toggle: "tooltip", placement: "top"},
                           title: 'Marital Status' %>
              <small class="text-danger"> <%= f.object.errors[:marital_status].present? ? f.object.errors[:marital_status]&.first : '' %> </small>
            </div>

            <div class="form-group">
              <%= f.select :religion,
                           MarriageProfile::religions.sort_by { |k, v| k }.to_h.map { |k, v| [k.humanize, k] },
                           {prompt: 'Religion*'},
                           required: true,
                           class: 'form-control sign_up-input-field',
                           data: {toggle: "tooltip", placement: "top" },
                           title:'Religion' %>
              <small class="text-danger"> <%= f.object.errors[:religion].present? ? f.object.errors[:religion]&.first : '' %> </small>
            </div>
            <div class="form-group" id="other_religion_field" style="display:none;">
              <%= f.text_field :other_religion, placeholder: 'Please specify your religion*', class: 'form-control sign_up-input-field', id: 'other_religion_input' %>
            </div>

            <div class="form-group">
              <%= f.select :hometown,
                           District.order_by_name.pluck(:name),
                           {prompt: 'Hometown*'},
                           class: 'form-control sign_up-input-field',
                           required: true,
			   placeholder: 'Date of Birth (dd/mm/yyyy)',   # behaves like prompt
                           data: {toggle: "tooltip", placement: "top" },
                           title:'Hometown* 🔐 (information cannot be edited once submitted)' %>
              <small class="text-danger"> <%= f.object.errors[:hometown].present? ? f.object.errors[:hometown]&.first : '' %> </small>
            </div>
	    <div id="hometown_abroad_fields" class="mb-3" style="display:none;">
              <div class="row mt-2">
                <div class="col-6">
		  <%= f.select :hometown_country, options_for_select(Country.order(:name).pluck(:name), f.object.hometown_country), {prompt: 'Country*'}, class: 'form-control sign_up-input-field', id: 'hometown_country_input' %>
                </div>
                <div class="col-6">
                  <%= f.text_field :hometown_city, placeholder: 'City*', class: 'form-control sign_up-input-field', id: 'hometown_city_input' %>
                </div>
              </div>
            </div>

            <div class="form-group">
              <%= f.select :present_location,
                           District.order_by_name.pluck(:name), {prompt: 'Present Location*'},
                           class: 'form-control sign_up-input-field',
                           required: true,
                           data: {toggle: "tooltip", placement: "top" },
                           title:'Present Location*' %>
              <small class="text-danger"> <%= f.object.errors[:present_location].present? ? f.object.errors[:present_location]&.first : '' %> </small>
            </div>
	    <div id="present_location_abroad_fields" class="mb-3" style="display:none;">
              <div class="row mt-2">
                <div class="col-6">
		  <%= f.select :present_location_country, options_for_select(Country.order(:name).pluck(:name), f.object.present_location_country), {prompt: 'Country*'}, class: 'form-control sign_up-input-field', id: 'present_location_country_input' %>
                </div>
                <div class="col-6">
                  <%= f.text_field :present_location_city, placeholder: 'City*', class: 'form-control sign_up-input-field', id: 'present_location_city_input' %>
                </div>
              </div>
            </div>

            <div class="form-group">
              <div class=" d-flex flex-row">
                <div class="flex-fill pr-1">
                  <%= f.select :height_ft,
                               MarriageProfile::height_fts.filter { |k, v| k != '0' },
                               {prompt: 'Height(ft)*'},
                               autofocus: true,
                               autocomplete: "height",
                               class: 'form-control sign_up-input-field',
                               placeholder: 'Height(ft)*',
                               required: true,
                               data: {toggle: "tooltip", placement: "top" },
                               title:'Height (ft)' %>
                  <small class="text-danger"> <%= f.object.errors[:height].present? ? f.object.errors[:height]&.first : '' %> </small>
                </div>
                <div class="flex-fill pl-1">
                  <%= f.select :height_inch,
                               MarriageProfile::height_inches,
                               {prompt: 'Height(inch)*'},
                               autofocus: true,
                               autocomplete: "height_inch",
                               class: 'form-control sign_up-input-field',
                               required: true,
                               data: {toggle: "tooltip", placement: "top" },
                               title:'Height (inch)' %>
                  <small class="text-danger"> <%= f.object.errors[:height_inch].present? ? f.object.errors[:height_inch]&.first : '' %> </small>
                </div>
              </div>
            </div>

            <div class="form-group">
              <%= f.select :highest_education_level,
                           MarriageProfile::highest_education_levels.sort_by { |k, v| k == 'other' ? 'zzz' : k }.to_h.map { |k, v| [k.humanize, k] },
                           {prompt: 'Highest Education Level*'},
                           class: 'form-control sign_up-input-field',
                           required: true,
                           data: {toggle: "tooltip", placement: "top" },
                           title:'Height Education Level' %>
              <small class="text-danger"> <%= f.object.errors[:highest_education_level].present? ? f.object.errors[:highest_education_level]&.first : '' %> </small>
            </div>
            <div class="form-group" id="other_education_field" style="display:none;">
              <%= f.text_field :other_education, placeholder: 'Please specify your education*', class: 'form-control sign_up-input-field', id: 'other_education_input' %>
            </div>

            <div class="form-group">
              <%= f.select :family_type,
                           MarriageProfile::family_types.filter { |k, v| k != 'does_not_matter'}.sort_by { |k, v| k }.to_h.map { |k, v| [k.humanize, k] },
                           {prompt: 'Family Type*'},
                           class: 'form-control sign_up-input-field',
                           required: true,
                           data: {toggle: "tooltip", placement: "top"},
                           title: 'Family Type' %>
              <small class="text-danger"> <%= f.object.errors[:family_type].present? ? f.object.errors[:family_values]&.first : '' %> </small>
            </div>

            <div class="form-group">
              <%= f.select :family_status,
                           MarriageProfile::family_statuses.filter { |k, v| k != 'does_not_matter' }.sort_by { |k, v| k }.to_h.map { |k, v| [k.humanize, k] },
                           {prompt: 'Family Status*'},
                           class: 'form-control sign_up-input-field',
                           required: true,
                           data: {toggle: "tooltip", placement: "top"},
                           title: 'Family Status' %>
              <small class="text-danger"> <%= f.object.errors[:family_status].present? ? f.object.errors[:family_status]&.first : '' %> </small>
            </div>
            <div class="form-group">
              <%= f.select :family_values,
                           MarriageProfile::family_values.filter { |k, v| k != 'does_not_matter' }.sort_by { |k, v| k }.to_h.map { |k, v| [k.humanize, k] },
                           {prompt: 'Family Values*'},
                           class: 'form-control sign_up-input-field',
                           required: true,
                           data: {toggle: "tooltip", placement: "top"},
                           title: 'Family Values' %>
              <small class="text-danger"> <%= f.object.errors[:family_values].present? ? f.object.errors[:family_values]&.first : '' %> </small>
            </div>

            <div class="form-group">
              <%= f.select :blood_group,
                           MarriageProfile::blood_groups.sort_by { |k, v| k }.to_h.map { |k, v| [k, k] },
                           {prompt: 'Blood Group*'},
                           autofocus: true,
                           class: 'form-control sign_up-input-field',
                           required: true,
                           data: {toggle: "tooltip", placement: "top" },
                           title:'Blood Group* 🔐' %>
              <small class="text-danger"> <%= f.object.errors[:blood_group].present? ? f.object.errors[:blood_group]&.first : '' %> </small>
            </div>

            <div class="register-btn-section text-center">
              <button type="submit" class="btn btn-sign_up form-control"> Next</button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<script>
document.addEventListener('DOMContentLoaded', function() {
  function setupOtherField(selectName, fieldId, inputId, triggerValue) {
    triggerValue = triggerValue || 'other';
    var select = document.querySelector('select[name="marriage_profile[' + selectName + ']"]');
    var field = document.getElementById(fieldId);
    var input = document.getElementById(inputId);
    if (!select || !field) return;
    function toggle() {
      if (select.value === triggerValue) {
        field.style.display = 'block';
        input.required = true;
      } else {
        field.style.display = 'none';
        input.required = false;
      }
    }
    select.addEventListener('change', toggle);
    toggle();
  }
  setupOtherField('gender', 'other_gender_field', 'other_gender_input');
  setupOtherField('religion', 'other_religion_field', 'other_religion_input');
  setupOtherField('highest_education_level', 'other_education_field', 'other_education_input');
  setupOtherField('hometown', 'hometown_abroad_fields', 'hometown_country_input', 'Outside Bangladesh');
  setupOtherField('present_location', 'present_location_abroad_fields', 'present_location_country_input', 'Outside Bangladesh');
});
</script>
</div>
