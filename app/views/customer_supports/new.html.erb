<div style="background:#f7f5f0; min-height:100vh; padding:24px 0;">
  <div class="container" style="max-width:560px;">
    <div style="border:0.5px solid #FAC775; border-radius:14px; overflow:hidden; box-shadow:1px 3px 9px rgba(0,0,0,0.07);">

      <!-- Header -->
      <div style="background:linear-gradient(135deg,#FFB627,#ffca5e); padding:24px; text-align:center;">
        <div style="width:52px; height:52px; background:rgba(255,255,255,0.3); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 12px;">
          <i class="fas fa-headset" style="font-size:22px; color:#412402;"></i>
        </div>
        <h2 style="font-size:20px; font-weight:700; color:#412402; margin:0 0 4px;">Customer Support</h2>
        <p style="font-size:13px; color:#633806; margin:0;">Submit your request and we'll get back to you shortly</p>
      </div>

      <!-- Form -->
      <div style="padding:24px; background:#fff;">
        <%= render 'customer_support_form', customer_support: @customer_support %>
      </div>

    </div>
  </div>
</div>
