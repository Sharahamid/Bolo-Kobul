<%= form_for cultural_value, remote: true do |f| %>
  <!-- Modal Header -->
  <%= render 'shared/modal_header', title: 'Cultural Value' %>

  <!-- Modal body -->
  <div class="modal-body">
    <div class="form_input_fields pl-2 pr-2">

      <div class="form-group">

        <%= f.text_field :nationality,
                         placeholder: 'Nationality',
                         class: 'form-control sign_up-input-field',
                         title: 'Nationality',
                         data: {toggle: 'tooltip', placement: 'top'} %>
        <small class="text-danger"> <%= f.object.errors[:nationality].present? ? "Nationality #{f.object.errors[:nationality]&.first}" : '' %> </small>
      </div>

      <div class="form-group">
        <%= f.select :birth_place, District.order(:name).pluck(:name, :id),
                     {prompt: 'Birth Place'},
                     class: 'form-control sign_up-input-field',
                     data: {toggle: "tooltip", placement: "top" },
                     title:'Birth Place' %>
        <small class="text-danger"> <%= f.object.errors[:birth_place].present? ? "Birth Place #{f.object.errors[:birth_place]&.first}" : '' %> </small>
      </div>
      <div id="birth_place_abroad_fields" class="mb-3" style="display:none;">
        <div class="row mt-2">
          <div class="col-6">
	    <%= f.select :birth_place_country, options_for_select(Country.order(:name).pluck(:name), f.object.birth_place_country), {prompt: 'Country*'}, class: 'form-control sign_up-input-field', id: 'birth_place_country_input' %>
          </div>
          <div class="col-6">
            <%= f.text_field :birth_place_city, placeholder: 'City*', class: 'form-control sign_up-input-field', id: 'birth_place_city_input' %>
          </div>
        </div>
      </div>


      <div class="form-group">
        <%= f.select :mother_tongue, User::LANGUAGES,
                     {prompt: 'Mother Tongue'},
                     class: 'form-control sign_up-input-field',
                     title: 'Mother Tongue',
                     data: {toggle: 'tooltip', placement:'top'}
        %>
        <small class="text-danger"> <%= f.object.errors[:mother_tongue].present? ? "Mother Tongue #{f.object.errors[:mother_tongue]&.first}" : '' %> </small>
      </div>

      <div class="form-group">
        <%= f.label :languages_spoken, 'Languages Spoken :' %><br/>
        <div class="d-sm-flex flex-sm-row flex-wrap">
          <% User::LANGUAGES.each do |value, id| %>
            <label class="check-box-lbl-item">
              <%= check_box_tag "cultural_value[languages_spoken][]",
                                id,
                                checked_languages_spoken(id) %>
              <span class="ck-box-lbl" title="<%= value %>" data-toggle='tooltip' data-placement="top">
              <%= value.to_s %>
              </span>
            </label>
          <% end %>
        </div>

      </div>

      <div class="form-group">
        <%= f.label :religion %>
        <% profile = current_active_profile %>
        <% religion_display = profile&.mr_other? ? (profile&.other_religion.present? ? profile.other_religion : 'Other') : profile&.religion&.humanize %>
        <p class="form-control sign_up-input-field" style="background:#f5f5f5; cursor:not-allowed;">
          <%= religion_display || 'Not specified' %>
        </p>
        <%= f.hidden_field :religion, value: cultural_value.religion %>
      </div>

      <div class="form-group">
        <%= f.select :born_or_reverted, User::BORN_OR_REVERTED,
                     {prompt: 'Born Or Reverted'},
                     class: 'form-control sign_up-input-field',
                     title: 'Born Or Reverted',
                     data: {toggle: 'tooltip', placement:'top'}
        %>
        <small class="text-danger"> <%= f.object.errors[:born_or_reverted].present? ? "Born or Reverted #{f.object.errors[:born_or_reverted]&.first}" : '' %> </small>
      </div>

      <div class="form-group">
        <%= f.select :attend_religious_event, User::BOOLEAN_DATA,
                     {prompt: 'Attend Religious Events'},
                     class: 'form-control sign_up-input-field',
                     title: 'Attend religious events',
                     data: {toggle: 'tooltip', placement:'top'}
        %>
        <small class="text-danger"> <%= f.object.errors[:attend_religious_event].present? ? "Attend religious events #{f.object.errors[:attend_religious_event]&.first}" : '' %> </small>
      </div>

      <div class="form-group">
        <%= f.text_area :political_view,
                        placeholder: 'Political View',
                     class: 'form-control sign_up-input-field',
                     title: 'Political View',
                     data: {toggle: 'tooltip', placement:'top'}
        %>
        <small class="text-danger"> <%= f.object.errors[:political_view].present? ? "Mother Tongue #{f.object.errors[:political_view]&.first}" : '' %> </small>
      </div>



    </div>
  </div>
  <script>
  (function() {
    var sel = document.querySelector('select[name="cultural_value[birth_place]"]');
    var field = document.getElementById('birth_place_abroad_fields');
    var input = document.getElementById('birth_place_country_input');
    if (!sel || !field) return;
    function toggle() {
      if (sel.value === '65') {
        field.style.display = 'block';
        input.required = true;
      } else {
        field.style.display = 'none';
        input.required = false;
      }
    }
    sel.addEventListener('change', toggle);
    toggle();
  })();
  </script>

  <!-- Modal footer -->
  <%= render 'shared/modal_footer', f: f %>
<% end %>
