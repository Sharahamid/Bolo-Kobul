<!DOCTYPE html>
<html>
<head>
  <title>Bolokobul</title>
  <%= favicon_link_tag 'bk.png' %>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <!-- Required meta tags -->
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <meta name="description" content="Find your ideal life partner with Bolokobul - a trusted matchmaking platform with FREE registration, privacy, and security">
  <!-- Google Analytics -->
  <script>
    (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
      (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
      m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
    })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');

    ga('create', 'UA-163228777-1', 'auto');
    ga('send', 'pageview');
  </script>
  <!-- End Google Analytics -->

  <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
  <%= javascript_pack_tag 'application', 'data-turbolinks-track': true %>

  <!-- Preload fonts -->
  <%= preload_link_tag 'Roboto-Black.ttf' %>
  <%= preload_link_tag 'Roboto-Bold.ttf' %>
  <%= preload_link_tag 'Roboto-Light.ttf' %>
  <%= preload_link_tag 'Roboto-Medium.ttf' %>
  <%= preload_link_tag 'Roboto-Regular.ttf' %>
  <%= preload_link_tag 'Roboto-Thin.ttf' %>
  <%= preload_link_tag 'Lobster-Regular.ttf' %>

  <!-- Bootstrap CSS -->
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" integrity="sha384-ggOyR0iXCbMQv3Xipma34MD+dH/1fQ784/j6cY/iJTQUOhcWr7x9JvoRxT2MZw1T" crossorigin="anonymous">
  <!-- Add the slick-theme.css if you want default styling -->
  <link rel="stylesheet" type="text/css" href="//cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick.css"/>
  <!-- Add the slick-theme.css if you want default styling -->
  <link rel="stylesheet" type="text/css" href="//cdn.jsdelivr.net/gh/kenwheeler/slick@1.8.1/slick/slick-theme.css"/>


</head>

<body class="body_bg" data-l>
<script async defer src="https://connect.facebook.net/en_US/sdk.js"></script>
<%= render 'shared/flash_message' %>
<%= render 'shared/animation' %>
<%= render 'shared/header' %>
<%= content_for?(:content) ? yield(:content) : yield %>
<%= render 'shared/modal' %>
<!-- fb chat widget -->
<%= render('layouts/fbchat') %>
<%= render 'shared/footer' %>

<!-- font awesome-->
<script src="https://kit.fontawesome.com/0210ff8ef7.js" crossorigin="anonymous"></script>

<!-- Custom Confirm Modal -->
<div id="bk-confirm-modal" style="display:none; position:fixed; inset:0; z-index:99999; align-items:center; justify-content:center; background:rgba(0,0,0,0.5); backdrop-filter:blur(3px);">
  <div style="background:#fff; border-radius:16px; padding:28px 24px 20px; max-width:320px; width:90%; box-shadow:0 8px 32px rgba(0,0,0,0.18); text-align:center;">
    <div style="width:52px; height:52px; background:linear-gradient(135deg,#FFB627,#ffca5e); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 14px;">
      <i class="fas fa-exclamation" style="color:#633806; font-size:22px;"></i>
    </div>
    <p id="bk-confirm-message" style="font-size:15px; color:#333; font-weight:600; margin-bottom:20px; line-height:1.5;"></p>
    <div style="display:flex; gap:10px;">
      <button id="bk-confirm-ok" style="flex:1; padding:10px; border-radius:10px; border:none; background:linear-gradient(135deg,#FFB627,#ffca5e); color:#633806; font-size:13px; cursor:pointer; font-weight:700;">Yes, Confirm</button>
      <button id="bk-confirm-cancel" style="flex:1; padding:10px; border-radius:10px; border:0.5px solid #ddd; background:#f5f5f5; color:#666; font-size:13px; cursor:pointer; font-weight:600;">No</button>
    </div>
  </div>
</div>
<script>
  (function() {
    var modal = document.getElementById('bk-confirm-modal');
    var msgEl = document.getElementById('bk-confirm-message');
    var okBtn = document.getElementById('bk-confirm-ok');
    var cancelBtn = document.getElementById('bk-confirm-cancel');
    var pendingEl = null;

    function showModal(msg, el) {
      msgEl.textContent = msg;
      modal.style.display = 'flex';
      pendingEl = el;
    }

    okBtn.addEventListener('click', function() {
      modal.style.display = 'none';
      if (pendingEl) {
        var el = pendingEl;
        pendingEl = null;
        el.removeAttribute('data-confirm');
        el.click();
        el.setAttribute('data-confirm', msgEl.textContent);
      }
    });

    cancelBtn.addEventListener('click', function() {
      modal.style.display = 'none';
      pendingEl = null;
    });

    modal.addEventListener('click', function(e) {
      if (e.target === modal) {
        modal.style.display = 'none';
        pendingEl = null;
      }
    });

    document.addEventListener('click', function(e) {
      var el = e.target.closest('[data-confirm]');
      if (!el) return;
      e.preventDefault();
      e.stopImmediatePropagation();
      showModal(el.getAttribute('data-confirm'), el);
    }, true);
  })();
</script>

</body>
</html>
