</head>

<body class="body_bg" data-l>
<script async defer src="https://connect.facebook.net/en_US/sdk.js"></script>
<%= render 'shared/flash_message' %>
<%= render 'shared/animation' %>
<%= render 'shared/header' %>
<%= content_for?(:content) ? yield(:content) : yield %>
<%= render 'shared/modal' %>
<!-- fb chat widget -->
<%= render('layouts/fbchat') %>
<%= render 'shared/footer' %>

<!-- font awesome-->
<script src="https://kit.fontawesome.com/0210ff8ef7.js" crossorigin="anonymous"></script>

<!-- Custom Confirm Modal -->
<div id="bk-confirm-modal" style="display:none; position:fixed; inset:0; z-index:99999; align-items:center; justify-content:center; background:rgba(0,0,0,0.5); backdrop-filter:blur(3px);">
  <div style="background:#fff; border-radius:16px; padding:28px 24px 20px; max-width:320px; width:90%; box-shadow:0 8px 32px rgba(0,0,0,0.18); text-align:center;">
    <div style="width:52px; height:52px; background:linear-gradient(135deg,#FFB627,#ffca5e); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 14px;">
      <i class="fas fa-exclamation" style="color:#633806; font-size:22px;"></i>
    </div>
    <p id="bk-confirm-message" style="font-size:15px; color:#333; font-weight:600; margin-bottom:20px; line-height:1.5;"></p>
    <div style="display:flex; gap:10px;">
      <button id="bk-confirm-ok" style="flex:1; padding:10px; border-radius:10px; border:none; background:linear-gradient(135deg,#FFB627,#ffca5e); color:#633806; font-size:13px; cursor:pointer; font-weight:700;">Yes, Confirm</button>
      <button id="bk-confirm-cancel" style="flex:1; padding:10px; border-radius:10px; border:0.5px solid #ddd; background:#f5f5f5; color:#666; font-size:13px; cursor:pointer; font-weight:600;">No</button>
    </div>
  </div>
</div>
<script>
  (function() {
    var modal = document.getElementById('bk-confirm-modal');
    var msgEl = document.getElementById('bk-confirm-message');
    var okBtn = document.getElementById('bk-confirm-ok');
    var cancelBtn = document.getElementById('bk-confirm-cancel');
    var pendingEl = null;

    function showModal(msg, el) {
      msgEl.textContent = msg;
      modal.style.display = 'flex';
      pendingEl = el;
    }

    okBtn.addEventListener('click', function() {
      modal.style.display = 'none';
      if (pendingEl) {
        var el = pendingEl;
        pendingEl = null;
        if (el.closest('.kobul_btn') || el.classList.contains('kobul_btn')) {
          if (typeof launchButterfly === 'function') {
            var rect = el.getBoundingClientRect();
            launchButterfly(rect.left + rect.width/2, rect.top + rect.height/2);
          }
        }
        el.removeAttribute('data-confirm');
        el.click();
        el.setAttribute('data-confirm', msgEl.textContent);
      }
    });

    cancelBtn.addEventListener('click', function() {
      modal.style.display = 'none';
      pendingEl = null;
    });

    modal.addEventListener('click', function(e) {
      if (e.target === modal) {
        modal.style.display = 'none';
        pendingEl = null;
      }
    });

    document.addEventListener('click', function(e) {
      var el = e.target.closest('[data-confirm]');
      if (!el) return;
      e.preventDefault();
      e.stopImmediatePropagation();
      showModal(el.getAttribute('data-confirm'), el);
    }, true);
  })();
</script>


<% bfly_config = ButterflyConfig.last %>
<% if bfly_config&.butterfly_animation %>
<!-- Butterfly click animation -->
<script>
var bkAnimConfig = {
  kobul1Recommendations: <%= bfly_config&.anim_kobul1_recommendations ? 'true' : 'false' %>,
  kobul1Request: <%= bfly_config&.anim_kobul1_request ? 'true' : 'false' %>,
  kobul2: <%= bfly_config&.anim_kobul2 ? 'true' : 'false' %>
};
</script>
<script>
function launchButterflyTo(originX, originY, targetId) {
  var targetEl = targetId ? document.getElementById(targetId) : null;
  if (!targetEl) { launchButterfly(originX, originY); return; }
  var tr = targetEl.getBoundingClientRect();
  var tx = tr.left + tr.width / 2;
  var ty = tr.top + tr.height / 2;
  var dx = tx - originX;
  var dy = ty - originY;
  var uid = Date.now();
  var arc = -Math.abs(dx) * 0.4;
  var style = document.createElement('style');
  style.textContent =
    '@keyframes bk-to-' + uid + ' {' +
    '  0%   { transform:translate(0,0) scale(1.3) rotate(-10deg); opacity:1; }' +
    '  25%  { transform:translate(' + (dx*0.25) + 'px,' + (dy*0.25 + arc) + 'px) scale(1.1) rotate(20deg); opacity:1; }' +
    '  50%  { transform:translate(' + (dx*0.5) + 'px,' + (dy*0.5 + arc*1.5) + 'px) scale(1.0) rotate(-15deg); opacity:1; }' +
    '  75%  { transform:translate(' + (dx*0.75) + 'px,' + (dy*0.75 + arc*0.8) + 'px) scale(0.7) rotate(10deg); opacity:0.8; }' +
    '  100% { transform:translate(' + dx + 'px,' + dy + 'px) scale(0.2) rotate(0deg); opacity:0; }' +
    '}';
  document.head.appendChild(style);
  var bf = document.createElement('div');
  bf.style.cssText = 'position:fixed;left:' + (originX-14) + 'px;top:' + (originY-14) + 'px;font-size:28px;z-index:99999;pointer-events:none;animation:bk-to-' + uid + ' 1.2s ease-in-out forwards;line-height:1;will-change:transform;';
  bf.textContent = '🦋';
  document.body.appendChild(bf);
  setTimeout(function() { bf.remove(); style.remove(); }, 1400);
}

function launchButterfly(originX, originY) {
  var uid = Date.now();
  var style = document.createElement('style');
  style.textContent =
    '@keyframes bk-bf-' + uid + ' {' +
    '  0%   { transform: translate(0,0) scale(1.2) rotate(-10deg); opacity:1; }' +
    '  25%  { transform: translate(-30px,-60px) scale(1.1) rotate(15deg); opacity:1; }' +
    '  50%  { transform: translate(20px,-120px) scale(1.0) rotate(-8deg); opacity:0.9; }' +
    '  75%  { transform: translate(-15px,-180px) scale(0.8) rotate(12deg); opacity:0.6; }' +
    '  100% { transform: translate(10px,-240px) scale(0.4) rotate(-5deg); opacity:0; }' +
    '}';
  document.head.appendChild(style);
  var bf = document.createElement('div');
  bf.style.cssText = [
    'position:fixed',
    'left:' + (originX - 16) + 'px',
    'top:' + (originY - 16) + 'px',
    'font-size:28px',
    'z-index:99999',
    'pointer-events:none',
    'animation:bk-bf-' + uid + ' 1.2s ease-out forwards',
    'line-height:1',
    'will-change:transform'
  ].join(';');
  bf.textContent = '🦋';
  document.body.appendChild(bf);
  setTimeout(function() { bf.remove(); style.remove(); }, 1400);
}

document.addEventListener('DOMContentLoaded', function() {
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.kobul_btn');
    if (!btn) return;
    if (btn.getAttribute('data-bk-done')) return;
    if (btn.getAttribute('data-confirm')) return;

    e.preventDefault();
    e.stopImmediatePropagation();

    var rect = btn.getBoundingClientRect();
    var ox = rect.left + rect.width / 2;
    var oy = rect.top + rect.height / 2;
    var targetId = btn.getAttribute('data-butterfly-target');
    var shouldAnimate = true;
    if (typeof bkAnimConfig !== 'undefined') {
      if (targetId === 'bk-target-requests-sent' && !bkAnimConfig.kobul1Recommendations) shouldAnimate = false;
      if (targetId === 'bk-target-chat-requests' && !bkAnimConfig.kobul1Request) shouldAnimate = false;
      if (targetId === 'bk-target-chats' && !bkAnimConfig.kobul2) shouldAnimate = false;
    }
    if (shouldAnimate) {
      if (targetId) {
        launchButterflyTo(ox, oy, targetId);
      } else {
        launchButterfly(ox, oy);
      }
    }

    setTimeout(function() {
      btn.setAttribute('data-bk-done', 'true');
      btn.click();
      setTimeout(function() { btn.removeAttribute('data-bk-done'); }, 500);
    }, 1200);
  }, true);
});
</script>
<% end %>

</body>
</html>
