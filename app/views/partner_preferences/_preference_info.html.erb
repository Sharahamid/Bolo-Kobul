<div class="card mt-3 mb-3">
  <div class="card-header d-flex justify-content-between align-items-center" style="background:#fff;">
    <h5 class="mb-0" style="color:#FFB627; font-weight:700;">Partner Preferences</h5>
    <%= link_to edit_partner_preference_path(preference), remote: true,
                data: {toggle: 'tooltip', placement: 'top'},
                title: 'Edit Preference',
                class: 'btn btn-sm',
                style: 'border:1px solid #FFB627; color:#FFB627;' do %>
      <i class="fa fa-pencil"></i> Edit
    <% end %>
  </div>
  <div class="card-body">
    <div class="row">

      <div class="col-md-6 col-12">
        <table class="table table-borderless table-sm">
          <tbody>
            <tr>
              <td class="text-muted" style="width:50%;">Looking For</td>
              <td><strong><%= preference.gender.present? ? current_active_profile.gender_translate(preference.gender) : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Min Age</td>
              <td><strong><%= preference.min_age.present? ? "#{preference.min_age} Years" : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Max Age</td>
              <td><strong><%= preference.max_age.present? ? "#{preference.max_age} Years" : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Min Height</td>
              <td><strong><%= preference.min_height.present? ? "#{preference.min_height}' #{preference.min_inch}\"" : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Max Height</td>
              <td><strong><%= preference.max_height.present? ? "#{preference.max_height}' #{preference.max_inch}\"" : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Physical Status</td>
              <td><strong><%= preference.physical_status.present? ? preference.physical_status.humanize : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Religion</td>
              <td><strong><%= preference.religion.present? ? preference.religion.map(&:to_s).map(&:humanize).join(', ') : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Hometown</td>
              <td><strong>
                <% if preference.hometown.present? && preference.hometown.length > 1 %>
                  <%= preference.hometown.drop(1).join(', ') %>
                <% else %>-<% end %>
              </strong></td>
            </tr>
            <tr>
              <td class="text-muted">Except (Hometown)</td>
              <td><strong>
                <% if preference.except_hometown.present? && preference.except_hometown.length > 0 %>
                  <%= preference.except_hometown.join(', ') %>
                <% else %>-<% end %>
              </strong></td>
            </tr>
            <tr>
              <td class="text-muted">Present Location</td>
              <td><strong>
                <% if preference.present_location.present? && preference.present_location.length > 1 %>
                  <%= preference.present_location.drop(1).join(', ') %>
                <% else %>-<% end %>
              </strong></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="col-md-6 col-12">
        <table class="table table-borderless table-sm">
          <tbody>
            <tr>
              <td class="text-muted" style="width:50%;">Marital Status</td>
              <td><strong><%= preference.marital_status.present? ? preference.marital_status.map(&:to_s).map(&:humanize).join(', ') : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Education Level</td>
              <td><strong><%= preference.highest_education_level.present? ? preference.highest_education_level.humanize : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Family Status</td>
              <td><strong><%= preference.family_status.present? ? preference.family_status.humanize : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Family Values</td>
              <td><strong><%= preference.family_values.present? ? preference.family_values.humanize : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Family Type</td>
              <td><strong><%= preference.family_type.present? ? preference.family_type.humanize : '-' %></strong></td>
            </tr>
            <tr>
              <td class="text-muted">Blood Group</td>
              <td><strong><%= preference.blood_group.present? ? preference.blood_group.join(', ') : '-' %></strong></td>
            </tr>
          </tbody>
        </table>
      </div>

    </div>
  </div>
</div>
