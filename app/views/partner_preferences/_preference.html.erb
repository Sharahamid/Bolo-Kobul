<div class="partner-requests pt-3">
  <% if preference.present? %>
    <div class="preference_info">
      <%= render 'partner_preferences/preference_info', preference: preference %>
    </div>
  <% else %>
    <div class="no-data-found alert text-center text-gray">
      <h4> No Data Found</h4>
    </div>
  <% end %>
</div>
