<div style="border:0.5px solid #eee; border-radius:12px; overflow:hidden; background:#fff; height:100%; display:flex; align-items:stretch;">
  <%= link_to Ad.active.about_us_page.first&.url || '#', target: '_blank', style: "display:block; width:100%;" do %>
    <%= image_tag Ad.about_us || 'about_ad.png',
                  style: "width:100%; height:100%; object-fit:contain; display:block; background:#fff;",
                  class: "img-responsive" %>
  <% end %>
</div>
