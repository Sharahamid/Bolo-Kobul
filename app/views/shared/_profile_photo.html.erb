<%= link_to profile.present? ? profile_info_marriage_profile_path(profile) : '#' do %>
  <%= image_tag profile&.profile_image.present? ?
                    profile.profile_image.url(:profile_thumb) :
                    (profile&.id == current_active_profile&.id ? 'bk-upload-photo.png' : 'bk.png'),
                width: '74', height:'74',
                class: 'img-thumbnail rounded-circle' %>
<% end %>
