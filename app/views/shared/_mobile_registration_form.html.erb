<div class="mobile-registration">
  <div class="mobile-sign-up-form">
    <div class="overlay">
      <div class="container text-center">
        <div class="mobile-reg-form">
          <div class="register text-center">
            <strong>Register Now</strong>
            <div class="reg_underline text-center">
              <%= image_tag 'white_reg_line.svg' %>
            </div>
          </div>
          <p class="note">These information will not be displayed to other users</p>
          <div class="bk-input-feilds">
            <%= form_for @user, url: user_registration_path do |f| %>

              <div class="<%= f.object.errors[:name].present? ? '' : 'form-group' %>">
                <%= f.text_field :name,
                                 autofocus: true,
                                 autocomplete: "full_name",
                                 required: true,
                                 class: 'form-control sign_up-input-field',
                                 placeholder: 'Full Name*'
                %>
                <small class="text-danger error-text">
                  <%= f.object.errors[:name].present? ? "Name #{f.object.errors[:name]&.first}" : '' %>
                </small>
              </div>

              <div class="<%= f.object.errors[:email].present? ? '' : 'form-group' %>">
                <%= f.email_field :email,
                                  autofocus: true,
                                  autocomplete: "email",
                                  class: 'form-control sign_up-input-field',
                                  placeholder: 'Email*' %>
                <small class="text-danger error-text">
                  <%= f.object.errors[:email].present? ? "Email #{f.object.errors[:email]&.first}" : '' %>
                </small>
              </div>

              <div class="<%= f.object.errors[:phone_number].present? ? '' : 'form-group' %>">
                <%= f.phone_field :phone_number,
                                  autofocus: true,
                                  autocomplete: "phone_number",
                                  required: true, class: 'form-control sign_up-input-field',
                                  placeholder: 'Mobile* (+8801XXXXXXXXX)' %>
                <small class="text-danger error-text">
                  <%= f.object.errors[:phone_number].present? ? "Mobile #{f.object.errors[:phone_number]&.first}" : '' %>
                </small>
              </div>

              <div class="<%= f.object.errors[:password].present? ? '' : 'form-group' %>">
                <div class="password-field-wrapper">
                  <%= f.password_field :password,
                                       autocomplete: "password",
                                       class: 'form-control sign_up-input-field',
                                       placeholder: 'Password*( Must be at least 6 characters )',
                                       minlength: '6',
                                       maxlength: '20',
                                       pattern: "(?=.*[a-z])(?=.*[A-Z]).{6,}",
                                       title: "Must have at least 6 characters including 1 uppercase and lowercase letter, 1 number, 1 special character.",
                                       data: {toggle: 'tooltip', placement: 'top'},
                                       id: 'mobile_password',
                                       required: true, 
                                       oninput: "mobileCheckPwd()" %>
                  <button type="button" class="password-eye-btn" onclick="togglePassword('mobile_password', this)">
                    <i class="fas fa-eye"></i>
                  </button>
                </div>
                <small class="text-danger error-text">
                  <%= f.object.errors[:password].present? ? "Password #{f.object.errors[:password]&.first}" : '' %>
                </small>
              </div>

              <div class="<%= f.object.errors[:password_confirmation].present? ? '' : 'form-group' %>">
                <div class="password-field-wrapper">
                  <%= f.password_field :password_confirmation,
                                       autocomplete: "new-password",
                                       class: 'form-control sign_up-input-field',
                                       placeholder: 'Confirm Password*',
                                       id: 'mobile_password_confirmation',
                                       required: true, 
                                       oninput: "mobileCheckPwd()" %>
                  <button type="button" class="password-eye-btn" onclick="togglePassword('mobile_password_confirmation', this)">
                    <i class="fas fa-eye"></i>
                  </button>
                </div>
                <small class="text-danger error-text" id="mobile_password_match_error">
                  <%= f.object.errors[:password_confirmation].present? ? "Passwords do not match" : '' %>
                </small>
              </div>

              <div class="<%= f.object.errors[:created_for].present? ? '' : 'form-group' %>">
                <%= f.select :created_for,
                             options_for_select(User::created_fors.to_h
                                                    .map {
                                                        |k, v| [k.titleize, k]
                                                    }),
                             {prompt: 'Created For*'},
                             required: true,
                             class: 'form-control sign_up-input-field' %>
                <small class="text-danger error-text">
                  <%= f.object.errors[:created_for].present? ? "Confirm Password #{f.object.errors[:created_for]&.first}" : '' %>
                </small>
              </div>

              <!--              <div class="notice pb-2">-->
              <!--                <span> (These information will <b>never</b> be disclosed through this platform) </span>-->
              <!--              </div>-->

              <div class="form-group form-check terms_and_condition">
                <label class="form-check-label">
                  <input class="form-check-input" type="checkbox" required> Have you read the
                  <a href="<%= terms_of_uses_path %>" target="_blank"> Terms of Use </a> &
                  <a href="<%= privacy_policies_path %>" target="_blank"> Privacy Policy </a> of Bolo Kobul?
                </label>
              </div>

              <%# Honeypot - hidden from humans %>
      <div style="display:none !important; visibility:hidden; position:absolute; left:-9999px;">
        <input type="text" name="user[website]" tabindex="-1" autocomplete="off" placeholder="Leave this empty">
      </div>
      <div class="register-btn-section text-center merriweather">
                <button type="submit" class="btn btn-sign_up form-control">Register Free</button>
              </div>
             
	      <script>
	        function mobileCheckPwd() {
                  var pwd = document.getElementById('mobile_password');
                  var conf = document.getElementById('mobile_password_confirmation');
                  var err = document.getElementById('mobile_password_match_error');
                  if (!pwd || !conf || !err) return;
                  if (conf.value.length === 0) {
                    err.textContent = '';
                  } else if (pwd.value.startsWith(conf.value)) {
                    err.textContent = '';
                  } else {
                    err.textContent = 'Passwords do not match';
                  }
                }

                function togglePassword(inputId, button) {
                  var input = document.getElementById(inputId);
                  if (input.type === "password") {
                    input.type = "text";
                    button.textContent = "🙈";
                  } else {
                    input.type = "password";
                    button.textContent = "👁️";
                  }
                }
              </script>                            
            <% end %>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>
