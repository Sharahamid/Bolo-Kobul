<div class="dropdown" style="display:inline-block;" id="actions_<%= profile.id %>">
  <span data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" style="cursor:pointer; font-size:18px; color:#aaa; padding:2px 8px; line-height:1;">
    &#8942;
  </span>
  <div class="dropdown-menu dropdown-menu-right" style="min-width:120px; font-size:13px;">
    <a href="#" class="dropdown-item text-danger"
       onclick="showBlockConfirm('<%= profile.id %>', '<%= block_profile_marriage_profile_path(profile) %>'); return false;">
      <i class="fas fa-ban" style="margin-right:6px;"></i> Block
    </a>
  </div>
</div>

<!-- Block Confirm Modal -->
<div id="blockModal_<%= profile.id %>" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:16px; padding:28px 24px; max-width:320px; width:90%; text-align:center; box-shadow:0 8px 32px rgba(0,0,0,0.2);">
    <div style="width:52px; height:52px; background:#FFF3CC; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
      <i class="fas fa-ban" style="color:#854F0B; font-size:22px;"></i>
    </div>
    <h5 style="color:#412402; font-weight:700; margin-bottom:8px;">Block Profile?</h5>
    <p style="color:#888; font-size:13px; margin-bottom:20px;">This profile will be blocked and removed from your lists.</p>
    <div style="display:flex; gap:10px;">
      <button onclick="confirmBlock('<%= profile.id %>', '<%= block_profile_marriage_profile_path(profile) %>')"
              style="flex:1; padding:10px; border-radius:10px; border:none; background:#FFB627; color:#412402; font-size:13px; font-weight:700; cursor:pointer;">
        Block
      </button>
      <button onclick="hideBlockConfirm('<%= profile.id %>')"
              style="flex:1; padding:10px; border-radius:10px; border:1px solid #ddd; background:#f5f5f5; color:#555; font-size:13px; cursor:pointer;">
        Cancel
      </button>
    </div>
  </div>
</div>

<script>
function showBlockConfirm(id, url) {
  var modal = document.getElementById('blockModal_' + id);
  modal.style.display = 'flex';
}
function hideBlockConfirm(id) {
  document.getElementById('blockModal_' + id).style.display = 'none';
}
function confirmBlock(id, url) {
  var card = document.getElementById('actions_' + id);
  var cardParent = card.closest('[data-profile-card]') || card.closest('.request-card') || card.parentElement.parentElement.parentElement.parentElement;
  fetch(url, { method: 'GET', credentials: 'include', headers: {'X-Requested-With': 'XMLHttpRequest'} })
    .then(function() { cardParent.style.display = 'none'; });
  hideBlockConfirm(id);
}
</script>
